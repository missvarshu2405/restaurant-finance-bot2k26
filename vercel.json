{
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install --include=dev && cd backend && npm install",
  "functions": {
    "api/**/*.js": {
      "includeFiles": "backend/**",
      "maxDuration": 60
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.js"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ],
  "crons": [
    {
      "path": "/api/cron/evening",
      "schedule": "30 15 * * *"
    },
    {
      "path": "/api/cron/monthly",
      "schedule": "0 18 1 * *"
    }
  ]
}
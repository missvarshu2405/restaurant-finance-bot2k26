# ============================================
# RestaurantLedger v2.0 — Environment Variables
# Copy this to .env and fill in your values
# ============================================

# Server
PORT=3001
NODE_ENV=development
JWT_SECRET=your-jwt-secret-change-this-in-production

# Supabase (leave empty to use in-memory store)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Google Gemini AI
GEMINI_API_KEY=
GEMINI_API_KEY_FALLBACK=

# Email — Nodemailer SMTP (or Resend)
EMAIL_ENABLED=false
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=noreply@restaurantledger.app

# WhatsApp — Meta Cloud API (optional)
WHATSAPP_ENABLED=false
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# File Upload
MAX_FILE_SIZE_MB=10
UPLOAD_DIR=./uploads
